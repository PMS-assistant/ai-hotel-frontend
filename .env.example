# StayIntel backend URL (required for AI chat).
# Copy to .env and adjust if your backend runs elsewhere.
VITE_API_BASE_URL=http://localhost:8000

# Cloudbeds OAuth Configuration (optional - for PMS integration)
# Get your Client ID from Cloudbeds Developer Portal
VITE_CLOUDBEDS_CLIENT_ID=your-cloudbeds-client-id
# Backend redirect URI must match Cloudbeds app settings
VITE_CLOUDBEDS_REDIRECT_URI=http://localhost:8000/auth/cloudbeds/callback
